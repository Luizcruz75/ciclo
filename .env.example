# ═══════════════════════════════════════════════
# CICLO — variáveis de ambiente
# Copie para .env.local e preencha.
# .env.local NUNCA é commitado.
# ═══════════════════════════════════════════════

# ─── Anthropic ───────────────────────────────
# 🔴 SÓ NO SERVIDOR. Nunca em componente client.
ANTHROPIC_API_KEY=

# ─── Supabase ────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=

# Pode ir ao client SE E SOMENTE SE o RLS estiver ligado.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 🔴 NUNCA sai do servidor. Ignora RLS.
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ─────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
